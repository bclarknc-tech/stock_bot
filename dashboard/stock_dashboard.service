[Unit]
Description=Stock Bot Web Dashboard
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/stock_bot/dashboard
EnvironmentFile=/home/ubuntu/stock_bot/.env
ExecStart=/home/ubuntu/stock_bot/venv/bin/python app.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
